<file path="src/styles.css">
:root {
  color-scheme: dark;
  font-family:
    Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
  background: #080807;
  color: #f0efe7;
  --bg: #080807;
  --panel: #11110f;
  --panel-2: #171713;
  --line: #302e25;
  --line-strong: #5c4d27;
  --gold: #d4af47;
  --gold-soft: rgba(212, 175, 71, 0.16);
  --green: #2bd894;
  --green-soft: rgba(43, 216, 148, 0.16);
  --red: #e36a5b;
  --muted: #a7a193;
  --text: #f0efe7;
}

* {
  box-sizing: border-box;
}

html,
body,
#root {
  width: 100%;
  height: 100%;
}

body {
  margin: 0;
  min-width: 320px;
  min-height: 100%;
  overflow: hidden;
  background:
    linear-gradient(90deg, rgba(212, 175, 71, 0.04) 1px, transparent 1px),
    linear-gradient(0deg, rgba(43, 216, 148, 0.035) 1px, transparent 1px),
    #080807;
  background-size: 48px 48px;
}

button,
input {
  font: inherit;
}

button {
  color: inherit;
}

input {
  width: 100%;
  min-width: 0;
  border: 1px solid var(--line);
  border-radius: 6px;
  background: #090908;
  color: var(--text);
  padding: 9px 10px;
  outline: none;
}

input:focus {
  border-color: var(--gold);
  box-shadow: 0 0 0 2px rgba(212, 175, 71, 0.15);
}

.app-shell {
  height: 100%;
  min-height: 0;
  display: grid;
  grid-template-rows: 64px 1fr;
  overflow: hidden;
}

.topbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20px;
  padding: 0 18px;
  border-bottom: 1px solid var(--line);
  background: rgba(8, 8, 7, 0.94);
}

.brand {
  display: flex;
  align-items: center;
  gap: 12px;
  min-width: 0;
}

.brand-mark {
  width: 38px;
  height: 38px;
  display: grid;
  place-items: center;
  border: 1px solid var(--line-strong);
  border-radius: 8px;
  color: var(--gold);
  background: var(--gold-soft);
  font-weight: 800;
  letter-spacing: 0;
}

.brand h1 {
  margin: 0;
  font-size: 17px;
  line-height: 1.1;
}

.brand p {
  margin: 3px 0 0;
  color: var(--muted);
  font-size: 12px;
}

.metric-strip {
  display: flex;
  align-items: center;
  gap: 10px;
  flex-wrap: wrap;
  justify-content: flex-end;
}

.metric {
  display: inline-flex;
  align-items: center;
  gap: 7px;
  min-height: 34px;
  padding: 0 10px;
  border: 1px solid var(--line);
  border-radius: 6px;
  color: #d8d3c3;
  background: rgba(17, 17, 15, 0.88);
  font-size: 13px;
  white-space: nowrap;
}

.metric svg {
  color: var(--green);
}

.workspace {
  min-height: 0;
  display: grid;
  grid-template-columns: 64px minmax(0, 1fr) 360px;
}

.left-rail {
  display: flex;
  flex-direction: column;
  gap: 8px;
  padding: 12px 8px;
  border-right: 1px solid var(--line);
  background: rgba(10, 10, 9, 0.94);
}

.rail-button {
  width: 48px;
  min-height: 52px;
  border: 1px solid var(--line);
  border-radius: 7px;
  background: #0f0f0d;
  color: var(--muted);
  display: grid;
  place-items: center;
  gap: 2px;
  cursor: pointer;
}

.rail-button span {
  font-size: 10px;
}

.rail-button.active,
.rail-button:hover {
  border-color: var(--gold);
  color: var(--gold);
  background: var(--gold-soft);
}

.main-stage {
  min-width: 0;
  min-height: 0;
  display: grid;
  grid-template-rows: 54px minmax(0, 1fr);
  border-right: 1px solid var(--line);
}

.stage-toolbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12px;
  padding: 8px 12px;
  border-bottom: 1px solid var(--line);
  background: rgba(13, 13, 11, 0.92);
}

.segmented {
  display: flex;
  border: 1px solid var(--line);
  border-radius: 7px;
  overflow: hidden;
}

.segmented button,
.icon-button,
.primary-button,
.upload-button,
.floating-reset {
  min-height: 34px;
  border: 1px solid var(--line);
  background: #10100e;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  border-radius: 6px;
  padding: 0 12px;
  cursor: pointer;
  white-space: nowrap;
}

.segmented button {
  border: 0;
  border-radius: 0;
  color: var(--muted);
}

.segmented button.selected {
  color: var(--gold);
  background: var(--gold-soft);
}

.toolbar-actions {
  display: flex;
  align-items: center;
  gap: 8px;
  min-width: 0;
  flex-wrap: wrap;
  justify-content: flex-end;
}

.icon-button input,
.upload-button input {
  display: none;
}

.icon-button:hover,
.upload-button:hover,
.floating-reset:hover {
  border-color: var(--gold);
  color: var(--gold);
}

.primary-button {
  border-color: rgba(43, 216, 148, 0.55);
  background: var(--green-soft);
  color: var(--green);
  font-weight: 700;
}

.map-panel,
.world-panel {
  min-height: 0;
  position: relative;
  overflow: hidden;
  background: #060605;
}

.map-panel {
  padding: 16px;
  overflow: auto;
}

.plan-stage {
  position: relative;
  width: 1220px;
  height: 520px;
  max-width: none;
  min-width: 760px;
  border: 1px solid var(--line-strong);
  border-radius: 8px;
  overflow: hidden;
  background: #10100e;
  box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.03);
}

.plan-grid {
  position: absolute;
  inset: 0;
  background:
    linear-gradient(rgba(212, 175, 71, 0.08) 1px, transparent 1px),
    linear-gradient(90deg, rgba(212, 175, 71, 0.08) 1px, transparent 1px),
    repeating-linear-gradient(0deg, rgba(255, 255, 255, 0.018), rgba(255, 255, 255, 0.018) 1px, transparent 1px, transparent 16px);
  background-size: 40px 40px, 40px 40px, 100% 16px;
  pointer-events: none;
}

.floor-plan-image {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  object-fit: contain;
  opacity: 0.76;
  background: #f6f3ed;
}

.tour-lines {
  position: absolute;
  inset: 0;
  z-index: 1;
  width: 100%;
  height: 100%;
  overflow: visible;
  pointer-events: none;
}

.tour-lines line {
  stroke: rgba(18, 161, 116, 0.78);
  stroke-width: 4;
  stroke-linecap: round;
  stroke-dasharray: 12 10;
  filter: drop-shadow(0 2px 4px rgba(0, 0, 0, 0.35));
}

.tour-lines circle {
  fill: var(--green);
  stroke: #07100c;
  stroke-width: 2;
}

.room-box {
  position: absolute;
  z-index: 2;
  border: 1px solid rgba(212, 175, 71, 0.55);
  background: rgba(212, 175, 71, 0.14);
  color: #fff9df;
  border-radius: 7px;
  padding: 8px;
  display: grid;
  grid-template-rows: 18px 1fr auto auto;
  gap: 3px;
  cursor: grab;
  user-select: none;
  box-shadow: 0 0 0 1px rgba(0, 0, 0, 0.25), 0 10px 28px rgba(0, 0, 0, 0.28);
}

.room-box.ready {
  border-color: rgba(43, 216, 148, 0.7);
  background: rgba(43, 216, 148, 0.12);
}

.room-box.selected {
  outline: 2px solid var(--gold);
  outline-offset: 2px;
}

.room-box.disabled-room {
  opacity: 0.48;
  border-style: dashed;
}

.room-box strong,
.room-box span,
.room-box small {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.room-box strong {
  font-size: 13px;
  align-self: end;
}

.room-box span,
.room-box small {
  font-size: 11px;
  color: #d8d0af;
}

.room-box-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  color: var(--gold);
}

.mini-tool {
  width: 22px;
  height: 22px;
  border: 1px solid rgba(212, 175, 71, 0.45);
  border-radius: 5px;
  background: rgba(0, 0, 0, 0.4);
  color: var(--gold);
  display: grid;
  place-items: center;
  cursor: pointer;
}

.scale-widget {
  position: absolute;
  right: 12px;
  bottom: 12px;
  z-index: 2;
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 8px;
  border: 1px solid var(--line);
  border-radius: 7px;
  background: rgba(8, 8, 7, 0.86);
}

.scale-widget label {
  display: flex;
  align-items: center;
  gap: 8px;
}

.scale-widget span {
  color: var(--muted);
  font-size: 12px;
}

.scale-widget input {
  width: 84px;
  padding: 6px 8px;
}

.right-panel {
  min-height: 0;
  overflow: auto;
  background: rgba(10, 10, 9, 0.96);
}

.room-panel {
  padding: 14px;
  display: flex;
  flex-direction: column;
  gap: 14px;
}

.panel-heading {
  display: flex;
  align-items: start;
  justify-content: space-between;
  gap: 10px;
}

.eyebrow {
  margin: 0 0 4px;
  color: var(--gold);
  text-transform: uppercase;
  font-size: 11px;
  font-weight: 800;
}

.panel-heading h2 {
  margin: 0;
  font-size: 20px;
  line-height: 1.15;
}

.danger-icon {
  width: 34px;
  height: 34px;
  border: 1px solid rgba(227, 106, 91, 0.4);
  border-radius: 6px;
  background: rgba(227, 106, 91, 0.08);
  color: var(--red);
  display: grid;
  place-items: center;
  cursor: pointer;
}

.danger-icon:disabled {
  opacity: 0.35;
  cursor: not-allowed;
}

.status-line,
.warning-line {
  min-height: 34px;
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 8px 10px;
  border: 1px solid rgba(43, 216, 148, 0.28);
  border-radius: 7px;
  color: var(--green);
  background: var(--green-soft);
}

.warning-line {
  border-color: rgba(227, 106, 91, 0.4);
  color: #ffb1a7;
  background: rgba(227, 106, 91, 0.1);
}

.form-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
