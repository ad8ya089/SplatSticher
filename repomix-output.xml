}

.world-calibration div,
.world-calibration button {
  min-height: 30px;
  display: inline-flex;
  align-items: center;
  gap: 6px;
}

.world-calibration button {
  border: 1px solid rgba(43, 216, 148, 0.42);
  border-radius: 6px;
  padding: 0 9px;
  color: var(--green);
  background: rgba(43, 216, 148, 0.11);
}

.world-hud div {
  display: inline-flex;
  align-items: center;
  gap: 7px;
}

.floating-reset {
  position: absolute;
  z-index: 4;
  right: 12px;
  top: 12px;
  background: rgba(8, 8, 7, 0.76);
}

.world-empty {
  position: absolute;
  inset: 0;
  z-index: 3;
  display: grid;
  place-items: center;
  align-content: center;
  gap: 8px;
  pointer-events: none;
  background: radial-gradient(circle at center, rgba(212, 175, 71, 0.08), transparent 38%);
}

.world-empty h2 {
  margin: 0;
  font-size: 24px;
}

.world-empty p {
  margin: 0;
  color: var(--muted);
}

.empty-panel {
  padding: 18px;
  color: var(--muted);
}

@media (max-width: 1050px) {
  .workspace {
    grid-template-columns: 54px minmax(0, 1fr);
    grid-template-rows: minmax(0, 1fr) 420px;
  }

  .right-panel {
    grid-column: 1 / -1;
    border-top: 1px solid var(--line);
  }
}

@media (max-width: 760px) {
  .app-shell {
    grid-template-rows: auto 1fr;
  }

  .topbar {
    align-items: start;
    flex-direction: column;
    padding: 12px;
  }

  .metric-strip {
    justify-content: start;
  }

  .workspace {
    grid-template-columns: 1fr;
    grid-template-rows: auto minmax(0, 1fr) 430px;
  }

  .left-rail {
    flex-direction: row;
    border-right: 0;
    border-bottom: 1px solid var(--line);
    overflow-x: auto;
  }

  .rail-button {
    width: 64px;
  }

  .stage-toolbar {
    align-items: stretch;
    flex-direction: column;
  }

  .toolbar-actions {
    justify-content: start;
  }

  .right-panel {
    grid-column: auto;
  }

  .form-grid,
  .upload-row,
  .facts {
    grid-template-columns: 1fr;
  }
}
